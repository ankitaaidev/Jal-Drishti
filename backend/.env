# Copy this file to .env and fill in your real values.
# See docs/GEE_SETUP.md for how to get the GEE service account credentials.

# --- Demo mode ---
# Set to true to run the whole API with clearly-labeled SYNTHETIC data
# instead of calling Earth Engine/Open-Meteo. Useful for demoing the API
# shape and frontend before GEE credentials are ready. Every response in
# this mode includes "data_source": "SYNTHETIC_DEMO_DATA" - never present
# these numbers as real measurements. Set to false for the real pipeline.
DEMO_MODE=false

# --- Google Earth Engine (REQUIRED for real satellite data) ---
GEE_PROJECT_ID=jal-drishti-500712
GEE_SERVICE_ACCOUNT_EMAIL=jal-drishti@jal-drishti-500712.iam.gserviceaccount.com
GEE_SERVICE_ACCOUNT_KEY_PATH=./gee-key.json

# --- Database ---
# Leave as sqlite for zero-setup demo:
DATABASE_URL=sqlite:///./jaldrishti.db
# Or point at Postgres+PostGIS for production:
# DATABASE_URL=postgresql://user:password@host:5432/jaldrishti
